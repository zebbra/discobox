NETDISCO_URL=https://netdisco.example.com
NETDISCO_USERNAME=your_netdisco_username
NETDISCO_PASSWORD=your_netdisco_password

NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=your_netbox_token_here

# Set to false to disable TLS verification (not recommended in production)
NETBOX_TLS_VERIFY=true
NETDISCO_TLS_VERIFY=true

# Server mode
DISCOBOX_PORT=8080
DISCOBOX_WORKERS=4
DISCOBOX_AUTH_TOKEN=
DISCOBOX_METRICS_PATH=/metrics

# Sync feature defaults (server mode).
# Set NO_* to true to disable a feature globally; can still be overridden per-request.
# DISCOBOX_NO_MAC=true
DISCOBOX_NO_IP=true # netdisco is not VRF aware!
# DISCOBOX_NO_MODULES=true
# DISCOBOX_NO_SFP=true
# DISCOBOX_NO_POE=true
DISCOBOX_HOUSEKEEPING=true

# How to handle HA VIP placeholder devices (e.g. p0h / node0) when a cluster is detected.
# threenode (default) — add the VIP device as VC member at position 0; keep it and its IPs
# soft               — unassign IPs from the VIP device so physical nodes can claim them; keep the device record
# hard               — delete the VIP device entirely
# off                — do nothing
DISCOBOX_VIP_MODE=soft
