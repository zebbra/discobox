    {
      "id": 29,
      "title": "Device sync status",
      "type": "table",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 43},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Failed"}]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Device"},
            "properties": [
              {"id": "custom.width", "value": 320},
              {"id": "links", "value": []}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Failed"},
            "properties": [
              {"id": "custom.width", "value": 110},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "basic"}},
              {"id": "color", "value": {"mode": "thresholds"}},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "red",   "value": 1}
                ]
              }},
              {"id": "mappings", "value": [
                {
                  "type": "value",
                  "options": {
                    "0": {"color": "green", "index": 0, "text": "OK"},
                    "1": {"color": "red",   "index": 1, "text": "FAILED"}
                  }
                }
              ]}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Duration"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 1},
              {"id": "custom.width", "value": 110}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Last sync age"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "decimals", "value": 0},
              {"id": "custom.width", "value": 130},
              {"id": "color", "value": {"mode": "thresholds"}},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green",  "value": null},
                  {"color": "yellow", "value": 3600},
                  {"color": "red",    "value": 86400}
                ]
              }}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Time"},
            "properties": [{"id": "custom.hidden", "value": true}]
          },
          {
            "matcher": {"id": "byName", "options": "job"},
            "properties": [{"id": "custom.hidden", "value": true}]
          },
          {
            "matcher": {"id": "byName", "options": "__name__"},
            "properties": [{"id": "custom.hidden", "value": true}]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance":  "Device",
              "Value #A":  "Failed",
              "Value #B":  "Duration",
              "Value #C":  "Last sync age"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
