          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "discobox_device_last_sync_duration_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "time() - discobox_device_last_sync_timestamp_seconds",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C"
        }
      ]
    }

