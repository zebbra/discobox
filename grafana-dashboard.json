        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum by (le) (rate(discobox_sync_duration_seconds_bucket[10m])))",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },

    {
