        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.9, sum by (le) (rate(discobox_sync_duration_seconds_bucket[10m])))",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },

    {
      "id": 13,
      "title": "p99 (10 m)",
      "type": "stat",
      "gridPos": {"h": 2, "w": 9, "x": 15, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "colorMode": "value",
