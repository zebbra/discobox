        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.5, sum by (le) (rate(discobox_sync_duration_seconds_bucket[10m])))",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "title": "p90 (10 m)",
      "type": "stat",
      "gridPos": {"h": 2, "w": 9, "x": 15, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
